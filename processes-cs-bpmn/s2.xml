      <loop mode="pre_test" condition="true">
        <manipulate id="a2" label="Calculate Date">if data.date.nil?
  data.date = '2025-01-01'
else
  tmp = Time.parse(data.date)
  tmp = tmp + 60*60*26
  if tmp.year &gt; 2025
    data.date = '2025-01-01'
  else
    data.date =  tmp.strftime('%Y-%m-%d')  
  end
end
data.hour = 0</manipulate>
