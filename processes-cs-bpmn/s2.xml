          <manipulate id="a6" label="Calculate Angle">hour = data.hour
sunrise = data.sunrise
sunset = data.sunset

day_length = sunset - sunrise
night_length = 24 - day_length

if sunrise &lt;= hour &amp;&amp; hour &lt;= sunset
  data.angle = (hour - sunrise) * (180 / day_length)
elsif hour &lt; sunrise
  data.angle = 360 - ((sunrise - hour) * (180 / night_length))
else
  data.angle = 180 + ((hour - sunset) * (180 / night_length))
end</manipulate>
