            <call id="a6" endpoint="construction_sites">
              <parameters>
                <label>Get Related Construction Sites</label>
                <method>:get</method>
                <arguments/>
              </parameters>
              <code>
                <prepare/>
                <finalize output="result">require 'georuby'
require 'geo_ruby/geojson'

data.construction_sites = {}

return unless result &amp;&amp; result.is_a?(Hash) &amp;&amp; result['features']

result['features']&amp;.each do |cs|
  o1 = GeoRuby::SimpleFeatures::Geometry.from_geojson(cs['geometry'].to_json)
  data.stopcoords.each do |k,sc|
    o2 = GeoRuby::SimpleFeatures::Point.from_x_y(*sc)
    res = o1.points.map do |t|
      o2.ellipsoidal_distance(t)
    end.min  
    if res &lt; 300
      data.construction_sites[k] ||= []
      data.construction_sites[k] &lt;&lt; cs['properties']['BEZEICHNUNG']
      data.construction_sites[k].uniq!
    end
  end
end</finalize>
