            <call id="a1" endpoint="monitor">
              <parameters>
                <label>Get Delays </label>
                <method>:get</method>
                <arguments/>
              </parameters>
              <code>
                <prepare>endpoints.monitor = endpoints.monitor + "&amp;" + data.stops.map{ |e| "stopID=" + e.to_s }.join("&amp;")</prepare>
                <finalize output="result">data.delay = {}
return unless result &amp;&amp; result.is_a?(Hash) &amp;&amp; result['data']

result['data']['monitors']&amp;.each do |m|
  stopId = m.dig("locationStop","properties","attributes","rbl").to_s
  name = m.dig("locationStop","properties","title")

  data.delay[stopId] ||= {}
  data.delay[stopId]['name'] = name
  data.delay[stopId]['delays'] ||= []
  data.delay[stopId]['reasons'] ||= []

  m.dig('lines').each do |l|
    lineID = l['lineId'].to_s
    if lineID == data.lineID.to_s
      l.dig('departures', 'departure')&amp;.each do |d|
        dt = d['departureTime']
        if dt.has_key? 'timeReal' then
          tp = Time.parse(dt['timePlanned'])
          tr = Time.parse(dt['timeReal'])
          delay = tr - tp
          data.delay[stopId]['delays'] &lt;&lt; delay
        end
      end
    end
  end
end

result['data']['trafficInfos']&amp;.each do |ti|
  if ti['relatedLines'].include? data.line.to_s
    ti['relatedStops']&amp;.each do |rs|
      if data.delay.has_key? rs.to_s
        data.delay[rs.to_s]['reasons'] &lt;&lt; ti['description']
      end
    end
  end
end</finalize>
